@model CLDV6211_POE_PART1.Models.ViewModels.EventFormViewModel

@{
    ViewData["Title"] = "New Event — EventEase";
}

<!-- Page Header -->
<div class="mb-4 pb-2 border-bottom">
    <h2 class="fw-bold mb-0">📅 New Event</h2>
    <p class="text-muted small mb-0">Fill in the details below to schedule a new event.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow border-0" style="border-radius:12px; overflow:hidden;">
            <!-- Card header banner -->
            <div class="py-3 px-4"
                 style="background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);">
                <h5 class="text-white fw-bold mb-0">Event Details</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>
                    <div asp-validation-summary="All" class="alert alert-danger small"></div>

                    <!-- Event Name -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">📋 Event Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter event name"
                               style="border-radius:8px;" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Start Date -->
                    <div class="mb-3">
                        <label asp-for="StartDate" class="form-label fw-semibold">🗓️ Start Date</label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>

                    <!-- End Date -->
                    <div class="mb-3">
                        <label asp-for="EndDate" class="form-label fw-semibold">🗓️ End Date</label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>

                    <!-- Venue -->
                    <div class="mb-4">
                        <label asp-for="VenueID" class="form-label fw-semibold">🏛️ Venue</label>
                        <select asp-for="VenueID" class="form-select" asp-items="Model.VenueSelectList"
                                        style="border-radius:8px;">
                        <option value="">-- Select a Venue --</option>
                        </select>
                        <span asp-validation-for="VenueID" class="text-danger small"></span>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">🖼️ Event Image (optional)</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2">
                        <input type="submit" value="Create Event"
                               class="btn px-4"
                               style="background-color:#e94560; color:white; border-radius:8px;" />
                        <a asp-action="Index"
                           class="btn btn-outline-secondary"
                           style="border-radius:8px;">
                            ← Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
