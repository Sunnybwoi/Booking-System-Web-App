using CLDV6211_POE_PART1.Data;
using CLDV6211_POE_PART1.Models;
using CLDV6211_POE_PART1.Models.ViewModels;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using System.Diagnostics;

namespace CLDV6211_POE_PART1.Controllers
{
    /*This class was auto created/generated by the IDE*/
    public class HomeController : Controller
    {
        private readonly CLDV6211_DbContext _context;

        public HomeController(CLDV6211_DbContext context)
        {
            _context = context;
        }

        // This action method retrieves data from the database and passes it to the view for display.
        // It supports an optional searchQuery parameter to filter the displayed Venues, Events and Bookings
        // so the home page search (placed on the top-right menu bar) matches the capabilities of the Bookings index.
        public async Task<IActionResult> Index(string searchQuery)
        {
            var venuesQuery = _context.Venues.AsQueryable();
            var eventsQuery = _context.Events.Include(e => e.Venue).AsQueryable();
            var bookingsQuery = _context.Bookings.Include(b => b.Event).ThenInclude(e => e.Venue).AsQueryable();

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                // Filter venues by name or location
                venuesQuery = venuesQuery.Where(v => v.Name.Contains(searchQuery) || v.Location.Contains(searchQuery));

                // Filter events by event name or associated venue name
                eventsQuery = eventsQuery.Where(e => e.Name.Contains(searchQuery) || (e.Venue != null && e.Venue.Name.Contains(searchQuery)));

                // Filter bookings by customer name, event name or venue name
                bookingsQuery = bookingsQuery.Where(b => b.CustomerName.Contains(searchQuery)
                                                        || (b.Event != null && b.Event.Name.Contains(searchQuery))
                                                        || (b.Event != null && b.Event.Venue != null && b.Event.Venue.Name.Contains(searchQuery)));

                ViewBag.SearchQuery = searchQuery;
            }

            var model = new HomeIndexViewModel
            {
                Venues = await venuesQuery.ToListAsync(),
                Events = await eventsQuery.ToListAsync(),
                Bookings = await bookingsQuery.ToListAsync()
            };

            return View(model);
        }

        public IActionResult Privacy()
        {
            return View();
        }

        // This action method handles errors and returns an error view with relevant information about the request.
        [ResponseCache(Duration = 0, Location = ResponseCacheLocation.None, NoStore = true)]
        public IActionResult Error()
        {
            return View(new ErrorViewModel { RequestId = Activity.Current?.Id ?? HttpContext.TraceIdentifier });
        }
    }
}