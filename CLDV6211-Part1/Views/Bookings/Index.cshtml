@model IEnumerable<CLDV6211_POE_PART1.Models.Booking>

@{
    ViewData["Title"] = "Bookings — EventEase";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h2 class="fw-bold mb-0">📋 Booking Management</h2>
        <p class="text-muted small mb-0">View and manage all bookings in the system.</p>
    </div>
    <a asp-action="Create"
       class="btn btn-sm px-4"
       style="background-color:#e94560; color:white; border-radius:8px;">
        + New Booking
    </a>
</div>

@* Part 2 — Success/Error alert banners for TempData feedback messages *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show small" role="alert">
        ⚠️ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show small" role="alert">
        ✅ @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* Part 2 — Search bar: filters bookings by customer name, event name, or venue name *@
<form method="get" class="mb-4">
    <div class="input-group" style="max-width:480px;">
        <input type="text" name="searchQuery" class="form-control"
               placeholder="Search by customer, event or venue..."
               value="@ViewBag.SearchQuery"
               style="border-radius:8px 0 0 8px;" />
        <button class="btn btn-sm px-3" type="submit"
                style="background-color:#0f3460; color:white; border-radius:0 8px 8px 0;">
            🔍 Search
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-2" style="border-radius:8px;">✕ Clear</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <!-- Empty State -->
    <div class="text-center py-5 text-muted">
        <h1>📋</h1>
        <h5>No Bookings Yet</h5>
        <p class="small">
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
            {
                <span>No bookings match your search.</span>
            }
            else
            {
                <span>No bookings have been made yet.</span>
            }
        </p>
        <a asp-action="Create" class="btn btn-sm btn-outline-success">+ New Booking</a>
    </div>
}
else
{
    @* Part 2 — Consolidated view: each booking now shows Event name, Venue name,
       and Venue location alongside the existing customer/status/date information. *@
    <ul class="list-group shadow-sm">
        @foreach (var item in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center mb-2" style="border-radius:8px;">
                <div>
                    <h6 class="fw-bold mb-1">
                        Booking #@item.BookingID — @item.CustomerName
                    </h6>
                    <p class="text-muted small mb-0">
                        📅 @(item.Event != null ? item.Event.Name : "No Event") |
                        🏛️ @(item.Event?.Venue?.Name ?? "—") |
                        📍 @(item.Event?.Venue?.Location ?? "—") |
                        📞 @item.ContactInfo |
                        🗓️ @item.CreatedAt.ToString("dd MMM yyyy") |
                        <span class="badge"
                              style="background-color: @(item.Status == "Pending" ? "#ffc107" : item.Status == "Cancelled" ? "#dc3545" : "#28a745");
                                             color: @(item.Status == "Pending" ? "black" : "white");">
                            @item.Status
                        </span>
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.BookingID"
                       class="btn btn-sm"
                       style="background-color:#e94560; color:white; border-radius:8px;">
                        View
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.BookingID"
                       class="btn btn-sm btn-outline-secondary"
                       style="border-radius:8px;">
                        Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.BookingID"
                       class="btn btn-sm btn-outline-danger"
                       style="border-radius:8px;">
                        Delete
                    </a>
                </div>
            </li>
        }
    </ul>
}
