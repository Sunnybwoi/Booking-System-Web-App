@model CLDV6211_POE_PART1.Models.ViewModels.HomeIndexViewModel
@using CLDV6211_POE_PART1
@using CLDV6211_POE_PART1.Models
<!--
    Home/Index.cshtml - The main landing page for the EventEase application. 
    It provides an overview of the application's features and quick access to key sections like Venues, Events, and Bookings. 
    The design is modern and user-friendly, with a focus on clear navigation and visual appeal.
    Generated with the assistance from Anthropic's Claude Sonnet 4.6, 
    using Microsoft Visual Studio IntelliSense for code completion and best practices in ASP.NET Core MVC development.
-->
@{
    ViewData["Title"] = "EventEase - Venue Booking System";
    var venues = Model.Venues ?? new List<Venue>();
    var events = Model.Events ?? new List<Event>();
}

<!-- Hero Section -->
<div class="hero-section text-white text-center py-5 mb-4"
     style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: 12px;">
    <div class="container">
        <img src="https://placehold.co/120x120/e94560/white?text=EE"
             alt="EventEase Logo"
             class="mb-3 rounded-circle"
             style="border: 3px solid #e94560;" />
        <h1 class="display-4 fw-bold">EventEase</h1>
        <p class="lead mb-4">Your all-in-one Venue Booking and Event Management Platform</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Venues" asp-action="Index"
               class="btn btn-lg px-4"
               style="background-color:#e94560; color:white; border-radius:8px;">
                Browse Venues
            </a>
            <a asp-controller="Events" asp-action="Index"
               class="btn btn-lg px-4"
               style="background-color:#0f3460; color:white; border:2px solid #e94560; border-radius:8px;">
                View Events
            </a>
            <a asp-controller="Bookings" asp-action="Index"
               class="btn btn-lg px-4"
               style="background-color:transparent; color:white; border:2px solid white; border-radius:8px;">
                Manage Bookings
            </a>
        </div>
    </div>
</div>

<!-- Stats Bar -->
<div class="row text-center mb-5">
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 py-3" style="border-left: 4px solid #e94560 !important; border-radius:10px;">
            <div class="card-body">
                <h2 class="fw-bold" style="color:#e94560;">🏛️</h2>
                <h5 class="fw-bold">Venue Management</h5>
                <p class="text-muted small">Add, update, and manage all available venues with capacity and location info.</p>
                <a asp-controller="Venues" asp-action="Create" class="btn btn-sm btn-outline-danger">+ Add Venue</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 py-3" style="border-left: 4px solid #0f3460 !important; border-radius:10px;">
            <div class="card-body">
                <h2 class="fw-bold" style="color:#0f3460;">📅</h2>
                <h5 class="fw-bold">Event Scheduling</h5>
                <p class="text-muted small">Schedule events at venues, set start and end dates, and avoid conflicts.</p>
                <a asp-controller="Events" asp-action="Create" class="btn btn-sm btn-outline-primary">+ Add Event</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm border-0 py-3" style="border-left: 4px solid #28a745 !important; border-radius:10px;">
            <div class="card-body">
                <h2 class="fw-bold" style="color:#28a745;">📋</h2>
                <h5 class="fw-bold">Booking Management</h5>
                <p class="text-muted small">Create and manage bookings with unique IDs and prevent double bookings.</p>
                <a asp-controller="Bookings" asp-action="Create" class="btn btn-sm btn-outline-success">+ New Booking</a>
            </div>
        </div>
    </div>
</div>

<!-- Featured Venues Section -->
<div class="mb-5">
    <h3 class="fw-bold mb-4 border-bottom pb-2">🏛️ Featured Venues</h3>
    @if (!venues.Any())
    {
        <div class="text-center py-5 text-muted">
            <h1>🏛️</h1>
            <h5>No Current Venues</h5>
            <p class="small">Get started by adding your first venue.</p>
            <a asp-controller="Venues" asp-action="Create" class="btn btn-sm btn-outline-danger">+ Add Venue</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var venue in venues)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow border-0 h-100" style="border-radius:12px; overflow:hidden;">
                        @if (!string.IsNullOrEmpty(venue.ImageURL))
                        {
                            <img src="@venue.ImageURL" class="card-img-top" alt="@venue.Name"
                                 style="height:200px; object-fit:cover;"
                                 onerror="this.src='https://placehold.co/600x300/0f3460/white?text=No+Image'" />
                        }
                        else
                        {
                            <img src="https://placehold.co/600x300/0f3460/white?text=No+Image"
                                 class="card-img-top" alt="@venue.Name" style="height:200px; object-fit:cover;" />
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@venue.Name</h5>
                            <p class="text-muted small">📍 @venue.Location | 👥 Capacity: @venue.Capacity</p>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-controller="Venues" asp-action="Details" asp-route-id="@venue.VenueID"
                               class="btn btn-sm w-100"
                               style="background-color:#e94560; color:white; border-radius:8px;">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Events Section -->
<div class="mb-5">
    <h3 class="fw-bold mb-4 border-bottom pb-2">📅 Events</h3>
    @if (!events.Any())
    {
        <div class="text-center py-5 text-muted">
            <h1>📅</h1>
            <h5>No Current Events</h5>
            <p class="small">No events have been scheduled yet.</p>
            <a asp-controller="Events" asp-action="Create" class="btn btn-sm btn-outline-primary">+ Add Event</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var ev in events)
            {
                // Determine status and matching badge colour based on StartDate and EndDate
                string eventStatus;
                string badgeColour;

                if (ev.EndDate < DateTime.Now)
                {
                    eventStatus  = "Finished";
                    badgeColour  = "#6c757d"; // grey
                }
                else if (ev.StartDate > DateTime.Now)
                {
                    eventStatus  = "Upcoming";
                    badgeColour  = "#0f3460"; // dark blue
                }
                else
                {
                    eventStatus  = "Ongoing";
                    badgeColour  = "#e94560"; // red
                }
                <div class="col-md-4 mb-4">
                    <div class="card shadow border-0 h-100" style="border-radius:12px; overflow:hidden;">
                        @if (!string.IsNullOrEmpty(ev.ImageURL))
                        {
                            <img src="@ev.ImageURL" class="card-img-top" alt="Event image"
                                 style="height:220px; object-fit:cover;" />
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center"
                                 style="height:220px;background-color:#123a5b;color:white;font-size:48px;">
                                <span>No image</span>
                            </div>
                        }
                        <div class="card-body">
                            <span class="badge mb-2" style="background-color:@badgeColour;">
                                @eventStatus
                            </span>
                            <h5 class="card-title fw-bold">@ev.Name</h5>
                            <p class="text-muted small">
                                📍 @(ev.Venue != null ? ev.Venue.Name : "No Venue") |
                                🗓️ @ev.StartDate.ToString("dd MMM") – @ev.EndDate.ToString("dd MMM yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-controller="Bookings" asp-action="Create"
                               class="btn btn-sm w-100 btn-outline-success">
                                Book Now
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Bookings Section -->
<div class="mb-5">
    <h3 class="fw-bold mb-4 border-bottom pb-2">📋 All Bookings</h3>
    @{
        var bookings = Model.Bookings ?? new List<Booking>();
    }
    @if (!bookings.Any())
    {
        <div class="text-center py-5 text-muted">
            <h1>📋</h1>
            <h5>No Current Bookings</h5>
            <p class="small">No bookings have been made yet.</p>
            <a asp-controller="Bookings" asp-action="Create" class="btn btn-sm btn-outline-success">+ New Booking</a>
        </div>
    }
    else
    {
        <ul class="list-group shadow-sm">
            @foreach (var booking in bookings)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center mb-2" style="border-radius:8px;">
                    <div>
                        <h6 class="fw-bold mb-1">Booking #@booking.BookingID — @booking.CustomerName</h6>
                        <p class="text-muted small mb-0">
                            📅 @(booking.Event != null ? booking.Event.Name : "No Event") |
                            🏛️ @(booking.Event?.Venue != null ? booking.Event.Venue.Name : "No Venue") |
                            🗓️ @booking.CreatedAt.ToString("dd MMM yyyy") |
                            <span class="badge"
                                  style="background-color: @(booking.Status == "Pending" ? "#ffc107" : booking.Status == "Cancelled" ? "#dc3545" : "#28a745"); color: @(booking.Status == "Pending" ? "black" : "white");">
                                @booking.Status
                            </span>
                        </p>
                    </div>
                    <a asp-controller="Bookings" asp-action="Details" asp-route-id="@booking.BookingID"
                       class="btn btn-sm"
                       style="background-color:#e94560; color:white; border-radius:8px;">
                        View
                    </a>
                </li>
            }
        </ul>
    }
</div>

<!-- How It Works Section -->
<div class="mb-5 p-4 rounded" style="background: linear-gradient(135deg, #1a1a2e, #16213e); color:white;">
    <h3 class="fw-bold mb-4 text-center">⚙️ How It Works</h3>
    <div class="row text-center">
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <h1>1️⃣</h1>
                <h6 class="fw-bold">Browse Venues</h6>
                <p class="small text-white-50">Search available venues by location and capacity.</p>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <h1>2️⃣</h1>
                <h6 class="fw-bold">Select an Event</h6>
                <p class="small text-white-50">Choose or create an event to assign to a venue.</p>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <h1>3️⃣</h1>
                <h6 class="fw-bold">Make a Booking</h6>
                <p class="small text-white-50">Booking specialists confirm and log the booking.</p>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <h1>4️⃣</h1>
                <h6 class="fw-bold">Manage and Track</h6>
                <p class="small text-white-50">View, update, or cancel bookings at any time.</p>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions Footer Bar -->
<div class="card border-0 shadow-sm mb-4" style="border-radius:12px;">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h5 class="fw-bold mb-0">Ready to get started?</h5>
            <p class="text-muted small mb-0">Manage all your venue bookings in one place.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Venues" asp-action="Create" class="btn btn-danger btn-sm">+ New Venue</a>
            <a asp-controller="Events" asp-action="Create" class="btn btn-primary btn-sm">+ New Event</a>
            <a asp-controller="Bookings" asp-action="Create" class="btn btn-success btn-sm">+ New Booking</a>
        </div>
    </div>
</div>

