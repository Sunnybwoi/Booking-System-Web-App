<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CLDV6211_POE_PART1</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CLDV6211_POE_PART1</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    @{ 
                        var currentController = (ViewContext.RouteData.Values["controller"] ?? string.Empty).ToString();
                        var currentAction = (ViewContext.RouteData.Values["action"] ?? string.Empty).ToString();
                    }
                    @* Show a compact search box on the top-right only on the Home/Index page *@
                    @if (currentController == "Home" && currentAction == "Index")
                    {
                        <form method="get" asp-controller="Home" asp-action="SearchResults" class="d-flex ms-auto" style="max-width:420px;">
                            <div class="input-group">
                                <input type="text" name="searchQuery" class="form-control form-control-sm"
                                       placeholder="Search events, venues or bookings..."
                                       value="@ViewBag.SearchQuery"
                                       style="border-radius:8px 0 0 8px;" />
                                <button class="btn btn-sm" type="submit" style="background-color:#0f3460; color:white; border-radius:0 8px 8px 0;">🔍</button>
                                @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
                                {
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary ms-2" style="border-radius:8px;">✕</a>
                                }
                            </div>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CLDV6211_POE_PART1 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
