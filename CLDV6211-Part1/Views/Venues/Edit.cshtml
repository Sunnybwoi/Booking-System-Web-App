@model CLDV6211_POE_PART1.Models.Venue

@{
    ViewData["Title"] = "Edit Venue — EventEase";
}

<div class="mb-4 pb-2 border-bottom">
    <h2 class="fw-bold mb-0">✏️ Edit Venue</h2>
    <p class="text-muted small mb-0">Update details for Venue #@Model.VenueID.</p>
</div>

@* Part 2 — Success/Error alert banners *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show small" role="alert">
        ⚠️ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow border-0" style="border-radius:12px; overflow:hidden;">
            <div class="py-3 px-4" style="background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);">
                <h5 class="text-white fw-bold mb-0">@Model.Name</h5>
            </div>
            <div class="card-body p-4">
                @* Part 2 — enctype="multipart/form-data" required for file upload *@
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>
                    <input type="hidden" asp-for="VenueID" />
                    @* Part 2 — Preserve the existing blob URL so the controller knows to keep it if no new file is chosen *@
                    <input type="hidden" asp-for="ImageURL" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Name</label>
                        <input asp-for="Name" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">Location</label>
                        <input asp-for="Location" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold">Capacity</label>
                        <input asp-for="Capacity" class="form-control" style="border-radius:8px;" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>

                    @* Part 2 — Show the current blob image if one exists, before the upload control *@
                    @if (!string.IsNullOrEmpty(Model.ImageURL))
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">🖼️ Current Image</label><br />
                            <img src="@Model.ImageURL" alt="Current venue image"
                                 style="max-width:200px; max-height:150px; object-fit:cover; border-radius:8px; border:1px solid #dee2e6;" />
                        </div>
                    }

                    @* Part 2 — File upload replaces the plain ImageURL text input.
                       Leaving this field empty keeps the existing blob image unchanged. *@
                    <div class="mb-3">
                        <label for="imageFile" class="form-label fw-semibold">
                            🖼️ @(string.IsNullOrEmpty(Model.ImageURL) ? "Upload Image (optional)" : "Replace Image (optional)")
                        </label>
                        <input type="file" name="imageFile" id="imageFile" class="form-control"
                               accept="image/*" style="border-radius:8px;" />
                        <div class="form-text small text-muted">Leave empty to keep the current image.</div>
                        <span asp-validation-for="ImageURL" class="text-danger small"></span>
                    </div>

                    @* Part 2 — Preview new image before upload *@
                    <div class="mb-3" id="imagePreviewContainer" style="display:none;">
                        <label class="form-label fw-semibold small text-muted">New Image Preview</label><br />
                        <img id="imagePreview" src="#" alt="Preview"
                             style="max-width:200px; max-height:150px; object-fit:cover; border-radius:8px; border:1px solid #dee2e6;" />
                    </div>

                    <div class="d-flex gap-2">
                        <input type="submit" value="Save Changes" class="btn px-4" style="background-color:#e94560; color:white; border-radius:8px;" />
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:8px;">← Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    @* Part 2 — Image preview script for the replacement upload *@
    <script>
        document.getElementById('imageFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                    document.getElementById('imagePreview').src = ev.target.result;
                    document.getElementById('imagePreviewContainer').style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                document.getElementById('imagePreviewContainer').style.display = 'none';
            }
        });
    </script>
}
