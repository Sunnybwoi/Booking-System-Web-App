@model CLDV6211_POE_PART1.Models.Venue

@{
    ViewData["Title"] = "Delete Venue — EventEase";
}

<div class="mb-4 pb-2 border-bottom">
    <h2 class="fw-bold mb-0">Delete Venue</h2>
    <p class="text-muted small mb-0">Are you sure you want to delete "@Model.Name"?</p>
</div>

<div class="card p-4 mb-4">
    <h5>@Model.Name</h5>
    <p class="text-muted">@Model.Location • Capacity: @Model.Capacity</p>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="VenueID" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Yes, delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
