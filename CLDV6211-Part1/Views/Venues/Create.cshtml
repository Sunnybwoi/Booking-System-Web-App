@model CLDV6211_POE_PART1.Models.Venue

@{
    ViewData["Title"] = "New Venue — EventEase";
}

<div class="mb-4 pb-2 border-bottom">
    <h2 class="fw-bold mb-0">🏛️ New Venue</h2>
    <p class="text-muted small mb-0">Add a new venue to the system.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow border-0" style="border-radius:12px; overflow:hidden;">
            <div class="py-3 px-4" style="background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);">
                <h5 class="text-white fw-bold mb-0">Venue Details</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">🏷️ Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Venue name" style="border-radius:8px;" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold">📍 Location</label>
                        <input asp-for="Location" class="form-control" placeholder="City, address" style="border-radius:8px;" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold">👥 Capacity</label>
                        <input asp-for="Capacity" class="form-control" placeholder="Maximum capacity" style="border-radius:8px;" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageURL" class="form-label fw-semibold">🖼️ Image URL (optional)</label>
                        <input asp-for="ImageURL" class="form-control" placeholder="https://..." style="border-radius:8px;" />
                        <span asp-validation-for="ImageURL" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <input type="submit" value="Create Venue" class="btn px-4" style="background-color:#e94560; color:white; border-radius:8px;" />
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:8px;">← Back to List</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
